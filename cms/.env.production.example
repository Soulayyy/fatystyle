APP_NAME="Faty Style Administration"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://admin.CHANGE_ME

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_TIMEZONE=Europe/Paris

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=CHANGE_ME
DB_PORT=5432
DB_DATABASE=fatystyle_cms
DB_USERNAME=fatystyle_cms
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_EXPIRE_ON_CLOSE=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

MAIL_MAILER=smtp
MAIL_SCHEME=smtp
MAIL_HOST=CHANGE_ME
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=no-reply@CHANGE_ME
MAIL_FROM_NAME="Faty Style"

CMS_DEFAULT_LOCALE=fr
CMS_SUPPORTED_LOCALES=fr
CMS_MFA_REQUIRED=true
CMS_CONTACT_RECIPIENT=fatystyle@hotmail.fr
CMS_CONTACT_DELIVERY=mail
CMS_CONTACT_RETENTION_MONTHS=36
CMS_TRASH_RETENTION_DAYS=30
CMS_VERSION_RETENTION_MONTHS=12
CMS_VERSION_RETENTION_COUNT=100
CMS_BACKUP_RETENTION_DAYS=30

CMS_PUBLIC_SITE_URL=https://www.CHANGE_ME
CMS_PUBLIC_RELEASE_PATH=/var/www/fatystyle-content-releases
CMS_PUBLIC_CONTENT_LINK=/var/www/fatystyle/data/content.json
CMS_PUBLIC_MEDIA_LINK=/var/www/fatystyle/assets/images/cms
CMS_RELEASE_KEEP_COUNT=20

CMS_MEDIA_MAX_UPLOAD_MB=20
CMS_MEDIA_MAX_PIXELS=60000000
CMS_MEDIA_WEBP_QUALITY=82

# Première installation uniquement. Supprimer ces valeurs après migrate --seed.
ADMIN_BOOTSTRAP_NAME=CHANGE_ME
ADMIN_BOOTSTRAP_EMAIL=CHANGE_ME
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_MINIMUM_14_CARACTERES

# Facultatif si un stockage S3 est configuré ultérieurement.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-3
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
